<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quora Posts</h1>
    <% for(post of posts){ %>
        <div class="post">
            <h2 class="user"> @ <%= post.username %></h2>
            <p class="content"><%= post.content %></p>
            
            <a href="/posts/<%=post.id%>">See in Detail</a>
            <a href="/posts/<%=post.id%>/edit">Edit</a>
        </div>
    
    <%}%>

    <br>
    <br>
    <br>
    <!-- <a href="/posts/new">Add New Post</a> -->
    <button onclick='/posts/new'>Add New Post</button>
</body>
</html>         